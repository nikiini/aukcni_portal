{% extends 'base.html.twig' %}
{% block title %}Obnovení hesla{% endblock %}
{% block body %}
<div class="karta">
    <h1>Obnovení hesla</h1>
    <p>Zadejte svůj e-mail, na který Vám pošleme odkaz pro nastavení nového hesla.</p>
    <form method="post" action="{{ path('reset_hesla_zadost') }}">
        <label for="email">E-mail</label>
        <input type="email" id="email" name="email" required>

        <div class="form-actions">
            <button type="submit" class="button">Odeslat odkaz</button>
        </div>
    </form>
</div>
{% endblock %}