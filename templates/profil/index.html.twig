{% extends 'base.html.twig' %}
{% block title %}Můj profil{% endblock %}

{% block body %}

    <div class="profil-layout">

        <section class="karta profil-sekce-hlavni">
            <h1>Můj profil</h1>
            <div class="profil-blok">
                {% if uzivatel.profilFoto %}
                    <div class="profil-foto-box" style="margin-bottom: 20px;">
                        <img src="{{ asset('uploads/profily/' ~ uzivatel.profilFoto) }}"
                             alt="Profilová fotografie"
                             class="profil-avatar"
                             style="max-width: 160px; border-radius: 12px;">
                    </div>

                {% endif %}
                <h2>Osobní údaje</h2>
                <div class="profil-dvojice">
                    <div class="profil-popisek">Celé jméno</div>
                    <div class="profil-hodnota">{{ uzivatel.celeJmeno }}
                        {% if uzivatel.role == 'ROLE_ADMIN' %}
                            <span class="badge-admin">ADMIN</span>
                        {% endif %}
                    </div>

                    <div class="profil-popisek">Uživatelské jméno</div>
                    <div class="profil-hodnota">{{ uzivatel.uzivatelskeJmeno }}</div>

                    <div class="profil-popisek">Email</div>
                    <div class="profil-hodnota">{{ uzivatel.email }}</div>

                    <div class="profil-popisek">Kredity</div>
                    <div class="profil-hodnota profil-kredity">{{ uzivatel.kredity }} Kč</div>
                </div>
            </div>

            <div class="prodil-blok dobijeni-box">
                <h2>Dobití kreditů</h2>
                <div class="dobijeni-tlacitka">
                    <a href="{{ path('stripe_dobit', {castka: 500}) }}" class="button">Dobít 500 Kč</a>
                    <a href="{{ path('stripe_dobit', {castka: 2000}) }}" class="button">Dobít 2000 Kč</a>
                    <a href="{{ path('stripe_dobit', {castka: 5000}) }}" class="button">Dobít 5000 Kč</a>
                    <a href="{{ path('stripe_dobit', {castka: 10000}) }}" class="button">Dobít 10000 Kč</a>
                    <a href="{{ path('stripe_vlastni_castka') }}" class="button">Jiná částka ?</a>
                </div>
            </div>
            <div class="profil-blok">
                <h2>Statistiky</h2>

                <div class="profil-dvojice">
                    <div class="profil-popisek">Aktivní aukce</div>
                    <div class="profil-hodnota">{{ pocetAktivnichAukci }}</div>

                    <div class="profil-popisek">Ukončené aukce</div>
                    <div class="profil-hodnota">{{ pocetUkoncenychAukci }}</div>
                </div>
            </div>

            <div class="form-actions">
                <a href="{{ path('profil_uprava') }}" class="button">Upravit profil</a>
            </div>
        </section>

        <aside class="karta">
            <h2>Vzhled aplikace</h2>
            <p>Můžete přepínat mezi světlým a tmavým režimem.</p>

            <button id="dark-mode" class="button button-secondary">
                Přepnout režim vzhledu
            </button>

            <hr style="margin: 18px 0; border: none; border-top: 1px solid var(--barva-okraju-jemna);">

            <p><strong>Rychlé odkazy</strong></p>

            <p><a href="{{ path('reset_hesla_zadost') }}">Změna hesla</a></p>
            <p><a href="{{ path('aukce_moje') }}">Moje aukce</a></p>
            <p><a href="{{ path('uzivatel_statistiky') }}">Moje statistiky</a></p>
            <p><a href="{{ path('stripe_vlastni_castka') }}">Dobít libovolnou částku</a></p>
        </aside>

    </div>

{% endblock %}
