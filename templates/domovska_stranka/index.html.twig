{% extends'base.html.twig' %}

{% block title %} Domovská stránka {% endblock %}

{% block body %}
    <section class="hero">
        <div class="hero-text">
            <h1 class="hero-title">Aukční portál</h1>
            <p class="hero-subtitle">Objev nové aukce, přihazuj a prodávej. Rychle a jednoduše.</p>
            <div class="hero-actions">
                <a class="button" href="{{ path('aukce') }}">Procházet aukce</a>
                {% if app.user %}
                <a class="button button-secondary" href="{{ path('aukce_moje') }}">Moje aukce</a>
                {% else %}
                <a class="button button-secondary" href="{{ path('app_login') }}">Přihlásit</a>
                {% endif %}
            </div>
        </div>

        <div class="hero-badges">
            <a href="{{ path('aukce', {sekce: 'doporucene'}) }}" class="hero-badge-button"><span>Doporučené</span><span class="hero-badge-pocet">{{ aukce|length }}</span></a>
            <a href="{{ path('aukce', {sekce: 'nove-dnes'}) }}" class="hero-badge-button"><span>Nově dnes</span><span class="hero-badge-pocet">{{ aukceNoveDnes|length }}</span></a>
            <a href="{{ path('aukce', {sekce: 'konci-brzy'}) }}" class="hero-badge-button"><span>Končí brzy</span><span class="hero-badge-pocet">{{ aukceKonciBrzy|length }}</span></a>
        </div>
    </section>
    <div class="homepage-layout">
        <aside class="homepage-sidebar">
            {% if app.user %}
                <div class="karta">
                    <h2>Váš účet</h2>
                    <p>Přihlášen(a) jako<br>
                        <strong>{{ app.user.celeJmeno }}</strong></p>
                    <a href="{{ path('profil') }}" class="button">Profil</a>
                    <a href="{{ path('aukce_moje') }}" class="button button-secondary">Moje aukce</a>
                    <form action="{{ path('app_logout') }}" method="post">
                        <button type="submit" class="button button-secondary">Odhlásit se</button>
                    </form>
                </div>
            {% else %}
                <div class="karta">
                    <h2>Vítejte</h2>
                    <p>Pro účast v aukcích se prosím přihlaste.</p>
                    <a class="button" href="{{ path('app_login') }}">Přihlásit</a>
                </div>
            {% endif %}
        </aside>

        <main class="homepage-main">
            <section>
                <h2 class="section-title">Doporučené</h2>
                {% if aukce is not empty %}
                    <div class="aukce-grid">
                        {% for jednaAukce in aukce %}
                            <a href="{{ path('aukce_detail', {verejneId: jednaAukce.verejneId}) }}" class="karta karta-link">

                                {% if jednaAukce.hlavniFoto %}
                                    <div class="aukce-thumbnail-wrapper">
                                        <img src="{{ asset('uploads/' ~ jednaAukce.hlavniFoto) }}"
                                             alt="{{ jednaAukce.nazev }}"
                                             class="aukce-thumbnail">
                                    </div>
                                {% endif %}

                                <h3 class="aukce-title">{{ jednaAukce.nazev }}</h3>
                                <p class="aukce-popis">{{ jednaAukce.popis }}</p>
                                <p class="aukce-price">
                                    <strong>Vyvolávací cena: </strong>{{ jednaAukce.vychoziCena }} Kč
                                </p>
                            </a>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="karta">
                        <p>Zatím zde nejsou žádné aukce.</p>
                    </div>
                {% endif %}
            </section>

        {% if aukceNoveDnes is not empty %}
        <section class="homepage-subsekce">
            <h2 class="section-title">Nově dnes</h2>
            <div class="aukce-grid">
                {% for jednaAukce in aukceNoveDnes %}
                    <a href="{{ path('aukce_detail', {verejneId: jednaAukce.verejneId}) }}" class="karta karta-link">

                        {% if jednaAukce.hlavniFoto %}
                            <div class="aukce-thumbnail-wrapper">
                                <img src="{{ asset('uploads/' ~ jednaAukce.hlavniFoto) }}"
                                     alt="{{ jednaAukce.nazev }}"
                                     class="aukce-thumbnail">
                            </div>
                        {% endif %}

                        <h3 class="aukce-title">{{ jednaAukce.nazev }}</h3>
                        <p class="aukce-popis">{{ jednaAukce.popis }}</p>
                        <p class="aukce-price">
                            <strong>Vyvolávací cena: </strong>{{ jednaAukce.vychoziCena }} Kč
                        </p>
                    </a>
                {% endfor %}
            </div>
        </section>
        {% endif %}
        {% if aukceKonciBrzy is not empty %}
        <section class="homepage-subsekce">
            <h2 class="section-title">Končí brzy</h2>
            <div class="aukce-grid">
                {% for jednaAukce in aukceKonciBrzy %}
                    <a href="{{ path('aukce_detail', {verejneId: jednaAukce.verejneId}) }}" class="karta karta-link">

                        {% if jednaAukce.hlavniFoto %}
                            <div class="aukce-thumbnail-wrapper">
                                <img src="{{ asset('uploads/' ~ jednaAukce.hlavniFoto) }}"
                                     alt="{{ jednaAukce.nazev }}"
                                     class="aukce-thumbnail">
                            </div>
                        {% endif %}

                        <h3 class="aukce-title">{{ jednaAukce.nazev }}</h3>
                        <p class="aukce-popis">{{ jednaAukce.popis }}</p>
                        <p class="aukce-price">
                            <strong>Vyvolávací cena: </strong>{{ jednaAukce.vychoziCena }} Kč
                        </p>
                    </a>
                {% endfor %}
            </div>
        </section>
        {% endif %}

        </main>
    </div>
{% endblock %}